README.md

# ignore oh-my-zsh cache
.oh-my-zsh/cache
.oh-my-zsh/cache/.zsh-update
.oh-my-zsh/cache/completions
.oh-my-zsh/cache/grep-alias

# Local machine-specific zsh configuration (not managed by chezmoi)
.extra

# Claude Code - ignore machine-specific directories, but allow settings.json
.claude/backups
.claude/cache
.claude/file-history
.claude/history.jsonl
.claude/plans
.claude/plugins
.claude/projects
.claude/session-env
.claude/sessions
.claude/shell-snapshots
.claude/tasks
.claude/telemetry
# Note: .claude/settings.json and .claude/settings.local.json are managed

# .env file is managed by run_once_setup_env_file.sh from Bitwarden
.env

# tmux plugins are managed by tpm (plugin manager), not chezmoi
# Only tpm itself is managed via .chezmoiexternal.toml.tmpl
.tmux/plugins/*
!.tmux/plugins/tpm

# herdr: only the static config.toml is managed. Everything else is
# per-machine runtime state or auto-downloaded plugin code.
#   - plugins/        downloaded by herdr (analogous to node_modules / tpm plugins)
#   - plugins.json    mixes plugin list with machine-specific install state
#   - session.json    live workspace/tab/pane layout, changes every run
#   - *.log, *.sock   runtime logs and unix sockets
.config/herdr/plugins
.config/herdr/plugins.json
.config/herdr/session.json
.config/herdr/*.log
.config/herdr/*.sock

