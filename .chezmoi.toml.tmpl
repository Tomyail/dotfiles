{{- $profile := default "" (env "CHEZMOI_PROFILE") -}}
{{- if eq $profile "" -}}
    {{- $profile = default "" (env "CHEZMOI_SCENE") -}}
{{- end -}}
{{- if eq $profile "" -}}
    {{- $choices := list "mac_home" "mac_office" "wsl_dev" "portable" -}}
    {{- $profile = promptChoice "Please select your profile" $choices -}}
{{- end -}}
{{- writeToStdout (printf "current profile is %s\n" $profile) -}}

[data]
    # Keep scene as a compatibility alias while templates are migrated.
    scene = "{{ $profile }}"
    profile = "{{ $profile }}"
