
{{- $claudeCmd := "claude" -}}
{{- if lookPath "mc" -}}
  {{- $claudeCmd = "mc --code" -}}
{{- end -}}

{{- $isDesktop := false -}}
{{- if eq .chezmoi.os "darwin" -}}
  {{- $isDesktop = true -}}
{{- else if eq .chezmoi.os "linux" -}}
  {{- $isWSL := contains "microsoft" (output "uname" "-r" | lower) -}}
  {{- if and (not $isWSL) (or (stat "/usr/share/xsessions") (stat "/usr/share/wayland-sessions")) -}}
    {{- $isDesktop = true -}}
  {{- end -}}
{{- end -}}

[data]
  claudeCommand    = {{ $claudeCmd | quote }}
  isWork           = {{ promptBool "Is this company computer?" }}
  isDesktop        = {{ $isDesktop }}
  personalGitName  = {{ promptString "Personal git name" | quote }}
  personalGitEmail = {{ promptString "Personal git email" | quote }}
  workGitName      = {{ promptString "Work git name" | quote }}
  workGitEmail     = {{ promptString "Work git email" | quote }}
  homeMemModel     = {{ promptString "Home claude-mem model (default: deepseek-v4-flash)" | quote }}
  workMemModel     = {{ promptString "Work claude-mem model" | quote }}
