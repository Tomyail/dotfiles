
{{- $claudeCmd := "claude" -}}
{{- if lookPath "mc" -}}
  {{- $claudeCmd = "mc --code" -}}
{{- end -}}

[data]
  claudeCommand = {{ $claudeCmd | quote }}
  gitName       = {{ promptString "Work git name" | quote }}
  gitEmail      = {{ promptString "Work git email" | quote }}
  gitHubUser    = {{ promptString "GitHub username" | quote }}
  personalName  = {{ promptString "Personal git name" | quote }}
  personalEmail = {{ promptString "Personal git email" | quote }}
