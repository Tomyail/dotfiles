#!/bin/bash

{{- if and (eq .chezmoi.os "linux") (or (eq .scene "wsl") (eq .scene "linux_server")) }}
set -eu

if ! command -v apt-get >/dev/null 2>&1; then
  echo "apt-get not found, skipping apt package installation"
  exit 0
fi

if [ "$(id -u)" -eq 0 ]; then
  SUDO=""
elif command -v sudo >/dev/null 2>&1; then
  SUDO="sudo"
else
  echo "sudo is required to install apt packages"
  exit 1
fi

packages=(
  ca-certificates
  curl
  wget
  git
  zsh
  tmux
  ripgrep
  fd-find
  fzf
  jq
  unzip
  htop
  rsync
  build-essential
  neovim
)

if grep -qi microsoft /proc/sys/kernel/osrelease 2>/dev/null; then
  packages+=(wslu)
fi

echo "Installing apt packages: ${packages[*]}"
$SUDO apt-get update
$SUDO apt-get install -y "${packages[@]}"
{{- else }}
exit 0
{{- end }}
